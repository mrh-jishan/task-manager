# Monorepo-wide OS and editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
*~

# Secrets and local environment files
.env
.env.*
!.env.example
!.env.sample
!.env.template
!.env*.example
!.env*.sample
!.env*.template
*.local

# Shared logs, caches, and local outputs
*.log
*.pid
*.pid.lock
.cache/
coverage/

# Terraform local state
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json
*.auto.tfvars
*.tfvars
!*.tfvars.example
backend.hcl
!backend.hcl.example

# Frontend (React / React Router / Vite)
frontend/node_modules/
frontend/.react-router/
frontend/build/
frontend/dist/
frontend/.vite/
frontend/.turbo/
frontend/.eslintcache
frontend/.npm/
frontend/.pnpm-store/
frontend/.yarn/
frontend/*.tsbuildinfo

# Backend (Rails)
backend/.bundle/
backend/.env*
!backend/.env.example
!backend/.env.sample
!backend/.env.template
backend/log/*
!backend/log/.keep
backend/tmp/*
!backend/tmp/.keep
backend/tmp/pids/*
!backend/tmp/pids/
!backend/tmp/pids/.keep
backend/storage/*
!backend/storage/.keep
backend/tmp/storage/*
!backend/tmp/storage/
!backend/tmp/storage/.keep
backend/vendor/bundle/
backend/db/*.sqlite3
backend/db/*.sqlite3-*
backend/config/*.key
backend/public/assets/
backend/public/packs/
backend/coverage/
backend/.byebug_history

# Keep documentation and committed Docker config in version control
!README*
!**/README*
!Dockerfile
!Dockerfile.*
!**/Dockerfile
!**/Dockerfile.*
!docker-compose.yml
!docker-compose.yaml
!docker-compose.*.yml
!docker-compose.*.yaml
