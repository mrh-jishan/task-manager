#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/../.." && pwd)"
COMPOSE_FILE="${REPO_ROOT}/docker-compose.dev.yml"

if [ -f "${REPO_ROOT}/.env" ]; then
  ENV_FILE="${REPO_ROOT}/.env"
else
  ENV_FILE="${REPO_ROOT}/.env.example"
fi

TEST_ARGS=()

for arg in "$@"; do
  TEST_ARGS+=("${arg#backend/}")
done

docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" up -d postgres
docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" run --rm --no-deps -e RAILS_ENV=test backend bundle exec rails db:prepare
docker compose --env-file "${ENV_FILE}" -f "${COMPOSE_FILE}" run --rm --no-deps -e RAILS_ENV=test backend bundle exec rails test "${TEST_ARGS[@]}"
